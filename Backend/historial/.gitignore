# =============================================================================
# .gitignore - Archivos y directorios a ignorar por Git
# =============================================================================
# Proyecto: Sistema de Historial Médico Obstétrico
# Backend: Django REST Framework
# =============================================================================

# =============================================================================
# VARIABLES DE ENTORNO Y CONFIGURACIÓN SENSIBLE
# =============================================================================
.env
.env.local
.env.*.local
*.env
env.py
secrets.py

# =============================================================================
# DIRECTORIOS DE ENTORNO VIRTUAL PYTHON
# =============================================================================
venv/
ENV/
env/
.venv
virtualenv/
.Python

# =============================================================================
# ARCHIVOS COMPILADOS DE PYTHON
# =============================================================================
*.py[cod]
*$py.class
*.so
__pycache__/
*.egg-info/
dist/
build/
*.egg

# =============================================================================
# DJANGO
# =============================================================================
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
/media
/staticfiles
/static
*.pot

# =============================================================================
# BASE DE DATOS
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# CACHE Y SESIONES
# =============================================================================
.cache/
*.pyc
__pycache__/

# =============================================================================
# IDE Y EDITORES
# =============================================================================
# PyCharm
.idea/
*.iml
*.iws
.idea_modules/

# VSCode
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# =============================================================================
# SISTEMA OPERATIVO
# =============================================================================
# MacOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# =============================================================================
# ARCHIVOS TEMPORALES
# =============================================================================
*.tmp
*.bak
*.swp
*~.nib
tmp/
temp/

# =============================================================================
# TESTING Y COBERTURA
# =============================================================================
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
coverage.xml
*.cover

# =============================================================================
# JUPYTER NOTEBOOKS
# =============================================================================
.ipynb_checkpoints
*.ipynb

# =============================================================================
# CELERY
# =============================================================================
celerybeat-schedule
celerybeat.pid

# =============================================================================
# ARCHIVOS DE MIGRACIÓN (OPCIONAL - DESCOMENTAR SI ES NECESARIO)
# =============================================================================
# */migrations/*.py
# !*/migrations/__init__.py

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
log/

# =============================================================================
# ARCHIVOS DE RESPALDO
# =============================================================================
*.backup
*.bck
backup/

# =============================================================================
# NODE MODULES (SI SE USA FRONTEND EN EL MISMO REPO)
# =============================================================================
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock
