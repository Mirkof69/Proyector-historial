[MASTER]
load-plugins=pylint_django
django-settings-module=settings
init-hook=import sys,os; sys.path.insert(0, os.path.abspath('.')); sys.path.insert(0, os.path.abspath('..'))
jobs=1
extension-pkg-allow-list=cv2

[FORMAT]
max-line-length=120

[MESSAGES CONTROL]
# C0415: import-outside-toplevel — Django uses lazy imports to avoid circular dependencies
# C0413: wrong-import-position — Django bootstrap requires some imports after django.setup()
# W0718: broad-exception-caught — Django web views intentionally catch broad exceptions for HTTP 500 handling
# R0801: duplicate-code — some duplication is acceptable in views
# C0302: too-many-lines — large Django views/models are common
# W0212: protected-access — Django internal patterns use _meta, _default_manager etc.
# R0902: too-many-instance-attributes — Django models can have many fields
# C0321: multiple-statements — utility scripts use inline statements
# C0301: line-too-long — covered by max-line-length=120
# R0914: too-many-locals — complex medical calculations require many variables
# R0912: too-many-branches — medical logic can have many decision branches
# R0915: too-many-statements — large Django views
# R0917: too-many-positional-arguments — some Django methods require many args
# C0411: wrong-import-order — complex Django imports can't always follow PEP8 order
# C0412: ungrouped-imports — same as above
# R0913: too-many-arguments — medical calculation functions need many parameters
# R0903: too-few-public-methods — utility classes can be small
# R1702: too-many-nested-blocks — medical logic nesting
# W0511: fixme — TODO comments indicate known future work
# C0104: blacklisted-name — some short names are domain-appropriate
# R5102: while-used — acceptable in utility code
# R0402: consider-using-from-import — style choice
# C0207: use-maxsplit-arg — style choice
# W0237: arguments-renamed — intentional parameter renaming
# W0221: arguments-differ — acceptable in Django overrides
disable=C0415,C0413,W0718,R0801,C0302,W0212,R0902,C0301,R0914,R0912,R0915,R0917,C0411,C0412,R0913,R0903,R1702,W0511,C0104,R5102,R0402,C0207,W0237,W0221,E1102

[DESIGN]
max-args=10
max-locals=20
max-returns=12
max-branches=20
max-statements=80
max-bool-expr=15
max-public-methods=30
min-public-methods=1
max-parents=20

[SIMILARITIES]
min-similarity-lines=6

[VARIABLES]
dummy-variables-rgx=_+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+$)|dummy|^ignored_|^unused_

[BASIC]
good-names=i,j,k,n,m,f,v,e,x,y,z,pk,id,qs,db,dt,ts,fn,fp,ok,re,ip,os,t,g,h,w,q,p,a,b,c,d,r,s,u,T,X,Y,lr,tp,tn,ex,cv,df,ax,mu,sd,hr,bp,hb,eg,ga,ci,ns,nb,bc,ab,cd,ef,gh,ij,kl,mn,op,qr,st,uv,wx,yz
const-naming-style=any
module-naming-style=any
argument-rgx=[a-z_][a-z0-9_]*$|[A-Z_][A-Z0-9_]*$|[A-Z][a-z0-9_]*$|[A-Z][_a-zA-Z0-9]*$
variable-rgx=[a-z_][a-z0-9_]*$|[A-Z_][A-Z0-9_]*$|[A-Z][a-z0-9_]*$|[A-Z][_a-zA-Z0-9]*$

[TYPECHECK]
ignored-classes=optparse.Values,thread._local,_thread._local,argparse.Namespace
generated-members=objects,DoesNotExist,MultipleObjectsReturned,id,pk,_meta,_default_manager,_base_manager,getRotationMatrix2D,warpAffine,resize,BORDER_REFLECT,VideoCapture,VideoWriter,RETR_EXTERNAL,CHAIN_APPROX_SIMPLE,findContours,drawContours,LINE_AA,putText,FONT_HERSHEY_SIMPLEX,cvtColor,COLOR_BGR2RGB,COLOR_RGB2BGR,imread,imwrite,imshow,waitKey,destroyAllWindows,to,load_state_dict,train,eval,parameters,state_dict,named_parameters,get_prep_value,crear_valores_prolactina,crear_valores_amh,crear_valores_he4,crear_valores_cea,crear_valores_funcion_hepatica,crear_valores_hepatitis_c,crear_valores_chlamydia_gonorrea,crear_valores_dimero_d
ignored-modules=cv2,tensorflow,torch,torchvision,sklearn,numpy,scipy,PIL,pydicom,graphmdl

[EXCEPTIONS]
overgeneral-exceptions=builtins.BaseException
