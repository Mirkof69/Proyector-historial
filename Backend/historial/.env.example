# =============================================================================
# ARCHIVO DE CONFIGURACIÓN DE VARIABLES DE ENTORNO - EJEMPLO
# =============================================================================
# Este archivo contiene las variables de entorno necesarias para el proyecto.
# INSTRUCCIONES:
# 1. Copiar este archivo como .env en el mismo directorio
# 2. Reemplazar los valores de ejemplo con los valores reales
# 3. NUNCA subir el archivo .env al repositorio (está en .gitignore)
# =============================================================================

# =============================================================================
# CONFIGURACIÓN DE DJANGO
# =============================================================================
# Clave secreta de Django (generar una nueva para producción)
# Usar: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-CAMBIAR-POR-CLAVE-SECRETA-REAL

# Modo de depuración (True para desarrollo, False para producción)
DEBUG=True

# Hosts permitidos (separados por comas)
# Ejemplo: localhost,127.0.0.1,midominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# =============================================================================
# Nombre de la base de datos
DB_NAME=Historial

# Usuario de PostgreSQL
DB_USER=postgres

# Contraseña de PostgreSQL
DB_PASSWORD=CAMBIAR-POR-PASSWORD-REAL

# Host de la base de datos
DB_HOST=localhost

# Puerto de PostgreSQL
DB_PORT=5433

# =============================================================================
# CONFIGURACIÓN DE REDIS (CACHE Y SESIONES)
# =============================================================================
# URL de Redis para cache
REDIS_URL=redis://127.0.0.1:6379/1

# =============================================================================
# CONFIGURACIÓN DE JWT (JSON WEB TOKENS)
# =============================================================================
# Tiempo de vida del access token (en minutos)
JWT_ACCESS_TOKEN_LIFETIME=60

# Tiempo de vida del refresh token (en horas)
JWT_REFRESH_TOKEN_LIFETIME=24

# =============================================================================
# CONFIGURACIÓN DE CORS (CROSS-ORIGIN RESOURCE SHARING)
# =============================================================================
# Orígenes permitidos para CORS (separados por comas)
# Ejemplo: http://localhost:3000,http://127.0.0.1:3000,https://miapp.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# CONFIGURACIÓN DE EMAIL (OPCIONAL - PARA RECUPERACIÓN DE CONTRASEÑAS)
# =============================================================================
# Backend de email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Host del servidor SMTP
EMAIL_HOST=smtp.gmail.com

# Puerto SMTP
EMAIL_PORT=587

# Usar TLS
EMAIL_USE_TLS=True

# Usuario de email
EMAIL_HOST_USER=tucorreo@gmail.com

# Contraseña de email
EMAIL_HOST_PASSWORD=tu-password-de-app

# Email predeterminado de envío
DEFAULT_FROM_EMAIL=noreply@historialmedico.com

# =============================================================================
# CONFIGURACIÓN DE ARCHIVOS ESTÁTICOS Y MEDIA
# =============================================================================
# URL base para archivos estáticos
STATIC_URL=/static/

# URL base para archivos media (uploads)
MEDIA_URL=/media/

# Directorio raíz para archivos media
MEDIA_ROOT=media

# =============================================================================
# CONFIGURACIÓN DE LOGGING
# =============================================================================
# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD ADICIONAL
# =============================================================================
# Usar cookies seguras (True en producción con HTTPS)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Tiempo de vida de sesión (en segundos)
SESSION_COOKIE_AGE=86400

# =============================================================================
# CONFIGURACIÓN DE TIMEZONE
# =============================================================================
# Zona horaria del sistema
TIME_ZONE=America/La_Paz

# Código de idioma
LANGUAGE_CODE=es-bo
