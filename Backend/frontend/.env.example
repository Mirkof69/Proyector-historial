# Config de ejemplo del frontend (copiar a .env y ajustar)

# ⚠️ IMPORTANTE — auth por cookies httpOnly:
# NO fijar REACT_APP_API_URL a un host distinto del que sirve la página.
# Si la página corre en http://localhost:3000 y la API se fija a
# http://127.0.0.1:8000, el navegador los trata como SITIOS DISTINTOS
# (SameSite) y NO envía las cookies de sesión → el login queda roto.
# Dejarlo comentado: api.ts usa el hostname de la página automáticamente.
# REACT_APP_API_URL=

REACT_APP_API_TIMEOUT=30000
REACT_APP_ENV=development
REACT_APP_DEFAULT_THEME=normal
DISABLE_ESLINT_PLUGIN=true
