{
  "entry": ["Backend/frontend/src/index.tsx"],
  "ignore": {
    "files": [
      "**/build/**",
      "**/dist/**",
      "**/node_modules/**"
    ],
    "rules": [
      "react-doctor/no-giant-component",
      "react-doctor/prefer-module-scope-pure-function",
